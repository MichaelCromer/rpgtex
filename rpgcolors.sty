\ExplSyntaxOn

\bool_new:N \g__rpg_colors_loaded_bool
\bool_gset_true:N \g__rpg_colors_loaded_bool

\RequirePackage{xcolor}

\definecolor {RPGCoral}    {HTML} {F3D7C1}
\definecolor {RPGCyan}     {HTML} {B5CEB8}
\definecolor {RPGGold1}    {HTML} {B89A67}
\definecolor {RPGGold2}    {HTML} {C9AD6A}
\definecolor {RPGGold3}    {HTML} {E69A28}
\definecolor {RPGGreen1}   {HTML} {E0E5C1}
\definecolor {RPGGreen2}   {HTML} {E8E6DC}
\definecolor {RPGGrey}     {HTML} {CACCBE}
\definecolor {RPGLavender} {HTML} {E3CED3}
\definecolor {RPGLilac}    {HTML} {D7D4D6}
\definecolor {RPGMauve}    {HTML} {DCCCC5}
\definecolor {RPGRed1}     {HTML} {9C2B1B}
\definecolor {RPGRed2}     {HTML} {58180D}
\definecolor {RPGSlate}    {HTML} {DBE4E4}
\definecolor {RPGTan1}     {HTML} {E5D5AC}
\definecolor {RPGTan2}     {HTML} {F7F2E5}
\definecolor {RPGTan3}     {HTML} {F9EFD6}
\definecolor {RPGTan4}     {HTML} {FDF1DC}

\colorlet {themecolor}      {RPGGreen2}     % Default theme
\colorlet {commentcolor}    {themecolor}     % RPGComment background
\colorlet {sidebarcolor}    {themecolor}     % RPGSidebar background
\colorlet {tablecolor}      {themecolor}     % RPGTable even row background
\colorlet {readaloudcolor}  {RPGTan1}       % RPGReadAloud background
\colorlet {titlecolor}      {RPGRed1}       % default titlerule color
\colorlet {rulecolor}       {RPGGold1}
\colorlet {statcolor}       {RPGTan4}
\colorlet {ribboncolor}     {RPGGold3}
\colorlet {contourcolor}    {RPGGrey}
\colorlet {footercolor}     {RPGGold1}

\NewDocumentCommand {\RPGSetThemeColor} { O {themecolor} }
{
    \colorlet {themecolor}   {#1}
    \colorlet {commentcolor} {#1}
    \colorlet {sidebarcolor} {#1}
    \colorlet {tablecolor}   {#1}
}
